NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy service_role JWT from Supabase Settings > API > Legacy API Keys.
# Required for server-side admin queries and internal API routes in this app.
SUPABASE_SECRET_KEY=
SUPABASE_SERVER_REQUEST_TIMEOUT_MS=15000
# Optional admin REST transport override: auto | native | powershell
# Default is auto: try native Node fetch first, then fall back to PowerShell on transport errors.
SUPABASE_ADMIN_REST_TRANSPORT=auto
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional dedicated secret for encrypted revealable family share links.
# If unset, the server falls back to SUPABASE_SERVICE_ROLE_KEY / SUPABASE_SECRET_KEY.
SHARE_LINK_TOKEN_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INVITE_EMAIL_REPLY_TO=
# supabase | object_storage | cloudflare_r2
MEDIA_STORAGE_BACKEND=supabase
NEXT_PUBLIC_STORAGE_BUCKET=tree-photos
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net
OBJECT_STORAGE_REGION=ru-central1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
# Cloudflare R2
CF_ACCOUNT_ID=
CF_R2_BUCKET=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_ENDPOINT=
CF_R2_REGION=auto
CF_R2_FORCE_PATH_STYLE=true
# Optional rollout gate for new uploads when MEDIA_STORAGE_BACKEND=cloudflare_r2.
# Before this UTC timestamp, new media stays on the legacy object-storage path.
CF_R2_ROLLOUT_AT=
# Development only: allows local server/API requests to act as a specific user without browser auth cookies.
DEV_IMPERSONATE_USER_ID=
DEV_IMPERSONATE_USER_EMAIL=
